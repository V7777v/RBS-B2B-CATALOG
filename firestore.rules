rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function userEmail() {
      return request.auth.token.email.lower();
    }
    function distDoc() {
      return get(/databases/$(database)/documents/approvedDistributors/$(userEmail())).data;
    }
    function isApproved() {
      return request.auth != null
        && exists(/databases/$(database)/documents/approvedDistributors/$(userEmail()));
    }
    function myRole() {
      return distDoc().get('role', 'user');
    }
    function isManager() {
      return isApproved() && myRole() == 'sales_manager';
    }
    function isAgent() {
      return isApproved() && (myRole() == 'agent' || myRole() == 'sales_manager');
    }
    function myAgentName() {
      return distDoc().get('agentName', '').trim();
    }

    // ---------- approved distributors: self-read only ----------
    match /approvedDistributors/{docEmail} {
      allow get: if request.auth != null && userEmail() == docEmail;
      allow list: if isManager();
      allow write: if false;
    }

    // ---------- per-user private data ----------
    match /carts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /favorites/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /userProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ---------- orders ----------
    match /orders/{orderId} {
      // only approved customers/agents may create, and only as themselves
      allow create: if isApproved()
        && request.resource.data.uid == request.auth.uid;

      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        isManager() ||
        (isAgent() && myAgentName() != '' && myAgentName() == resource.data.get('agent', '').trim())
      );

      // identity fields are immutable; owner / matching agent / manager may update the rest
      allow update: if request.auth != null
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email', 'createdAt'])
        && (
          resource.data.uid == request.auth.uid ||
          isManager() ||
          (isAgent() && myAgentName() != '' && myAgentName() == resource.data.get('agent', '').trim())
        );
    }

    // ---------- quotes ----------
    match /quotes/{quoteId} {
      allow read: if request.auth != null && (
        resource.data.agentUid == request.auth.uid ||
        resource.data.customerEmail == userEmail() ||
        isManager()
      );

      // only real agents/managers may create quotes, and only as themselves
      allow create: if isAgent() && request.resource.data.agentUid == request.auth.uid;

      allow update: if request.auth != null
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['agentUid', 'customerEmail', 'createdAt'])
        && (
          // owning agent: full edit only while the quote is NOT approved/signed
          (resource.data.agentUid == request.auth.uid && resource.data.get('status', '') != 'approved') ||
          // manager: escape hatch (corrections)
          isManager() ||
          // customer: signing path only — 4 fields, one-way, never after approval
          (resource.data.customerEmail == userEmail()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'signature', 'signedBy'])
            && resource.data.get('status', '') != 'approved')
        );

      // approved (signed) quotes cannot be deleted by the agent — manager only
      allow delete: if isManager()
        || (request.auth != null
            && resource.data.agentUid == request.auth.uid
            && resource.data.get('status', '') != 'approved');
    }

  }
}
