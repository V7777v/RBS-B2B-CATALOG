rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================================================
    // Authentication helpers
    // ==================================================

    function signedIn() {
      return request.auth != null;
    }

    function authEmailRaw() {
      return signedIn()
        ? request.auth.token.get('email', '')
        : '';
    }

    function hasEmail() {
      return signedIn()
        && authEmailRaw() is string
        && authEmailRaw().size() > 0;
    }

    function userEmail() {
      return authEmailRaw().lower().trim();
    }

    // approvedDistributors document IDs must be:
    // lowercase email, without leading/trailing spaces.
    function isApproved() {
      return hasEmail()
        && exists(
          /databases/$(database)/documents/approvedDistributors/$(userEmail())
        );
    }

    function myRole() {
      return isApproved()
        ? get(
            /databases/$(database)/documents/approvedDistributors/$(userEmail())
          ).data.get('role', 'user').lower().trim()
        : 'user';
    }

    function isManager() {
      return isApproved() && myRole() == 'sales_manager';
    }

    function isAgent() {
      return isApproved()
        && (
          myRole() == 'agent'
          || myRole() == 'sales_manager'
        );
    }

    function myAgentName() {
      return isApproved()
        ? get(
            /databases/$(database)/documents/approvedDistributors/$(userEmail())
          ).data.get('agentName', '').trim()
        : '';
    }

    function isNormalizedEmail(value) {
      return value is string
        && value.size() > 3
        && value == value.lower().trim();
    }

    // ==================================================
    // Approved distributors
    // ==================================================

    match /approvedDistributors/{docEmail} {

      // User may read only their own distributor record.
      // The document ID must equal the normalized auth email.
      allow get: if hasEmail()
        && userEmail() == docEmail;

      allow list: if isManager();

      // Managed only from Firebase Admin / Console.
      allow create, update, delete: if false;
    }

    // ==================================================
    // Per-user private data
    // ==================================================

    match /carts/{uid} {
      allow read, write: if signedIn()
        && request.auth.uid == uid;
    }

    match /favorites/{uid} {
      allow read, write: if signedIn()
        && request.auth.uid == uid;
    }

    match /userProfiles/{uid} {
      allow read, write: if signedIn()
        && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if signedIn()
        && request.auth.uid == uid;
    }

    // ==================================================
    // Orders
    // ==================================================

    match /orders/{orderId} {

      // Approved customers or agents may create
      // an order only for their own authenticated UID.
      allow create: if isApproved()
        && request.resource.data.uid == request.auth.uid;

      allow read: if signedIn() && (
        resource.data.uid == request.auth.uid
        || isManager()
        || (
          isAgent()
          && myAgentName() != ''
          && myAgentName()
            == resource.data.get('agent', '').trim()
        )
      );

      // Preserve identity fields.
      allow update: if signedIn()
        && !request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasAny([
            'uid',
            'email',
            'createdAt'
          ])
        && (
          resource.data.uid == request.auth.uid
          || isManager()
          || (
            isAgent()
            && myAgentName() != ''
            && myAgentName()
              == resource.data.get('agent', '').trim()
          )
        );

      allow delete: if false;
    }

    // ==================================================
    // Quotes helpers
    // ==================================================

    function validNewQuote() {
      return request.resource.data.keys().hasAll([
          'agentUid',
          'customerEmail',
          'status'
        ])
        && request.resource.data.agentUid is string
        && request.resource.data.agentUid
          == request.auth.uid
        && isNormalizedEmail(
          request.resource.data.customerEmail
        )
        && request.resource.data.status is string
        && request.resource.data.status in [
          'draft',
          'sent'
        ];
    }

    function quoteIdentityUnchanged() {
      return !request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasAny([
          'agentUid',
          'customerEmail',
          'createdAt'
        ]);
    }

    function isOwningAgent() {
      return isAgent()
        && resource.data.agentUid == request.auth.uid;
    }

    function isPublishedCustomerQuote() {
      return hasEmail()
        && resource.data.customerEmail == userEmail()
        && resource.data.get('status', '') in [
          'sent',
          'approved',
          'rejected'
        ];
    }

    function validCustomerQuoteUpdate() {
      return hasEmail()
        && resource.data.customerEmail == userEmail()

        // Customer may act only on a quote that was sent.
        && resource.data.get('status', '') == 'sent'

        // Customer may only approve or reject.
        && request.resource.data.get('status', '') in [
          'approved',
          'rejected'
        ]

        // Customer may not change products, prices,
        // discounts, customerEmail or agent data.
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'status',
            'updatedAt',
            'signature',
            'signedBy'
          ]);
    }

    // ==================================================
    // Quotes
    // ==================================================

    match /quotes/{quoteId} {

      // Agent reads their own quotes.
      // Manager reads all quotes.
      // Customer sees only published statuses — never draft.
      allow read: if signedIn() && (
        isOwningAgent()
        || isManager()
        || isPublishedCustomerQuote()
      );

      // Only an actual agent/manager may create a quote.
      // agentUid must always be their current Firebase Auth UID.
      allow create: if isAgent()
        && validNewQuote();

      allow update: if signedIn()
        && quoteIdentityUnchanged()
        && (
          // Owning agent may edit until approval.
          (
            isOwningAgent()
            && resource.data.get('status', '') != 'approved'
          )

          // Manager correction path.
          || isManager()

          // Customer one-way approval/rejection path.
          || validCustomerQuoteUpdate()
        );

      // Signed quotes cannot be deleted by an agent.
      allow delete: if isManager()
        || (
          isOwningAgent()
          && resource.data.get('status', '') != 'approved'
        );
    }

    // ==================================================
    // Default deny
    // ==================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
